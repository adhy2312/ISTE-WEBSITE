# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Node / Next.js ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.next/
/out/
/build

# ── Environment files ─────────────────────────────────────────────────────────
.env*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Prisma generated ─────────────────────────────────────────────────────────
/app/generated/prisma

# ── Python virtual environments ───────────────────────────────────────────────
.venv/
venv/
venv_ci/
env/
.env/
*.egg-info/
dist/

# ── Python cache / compiled bytecode ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# ── Compiled native engine binaries ──────────────────────────────────────────
scripts/bin/
go_engine/main
go_engine/main.exe
rust_engine/target/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
isolated_errors.log
chanakyan_v10.log

# ── SQLite databases (runtime artefacts — not source) ─────────────────────────
*.db
*.sqlite
*.sqlite3

# ── ML model weights & caches ─────────────────────────────────────────────────
*.pth
*.pt
*.ckpt
skill_embeddings_cache.json
ml_health_report.json
resume_ml_knowledge.json

# ── Playwright ────────────────────────────────────────────────────────────────
playwright-report/
test-results/

# ── Misc runtime artefacts ────────────────────────────────────────────────────
*.pem
.DS_Store
telemetry_ingest.json
diff.txt
test.txt

# ── VS Code (optional — remove if you want to share editor settings) ──────────
.vscode/
